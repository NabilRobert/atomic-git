# ============================================================
# Atomic Commit Machine — .gitignore
# ============================================================

# --- Secrets (NEVER commit) ---
.env
.env.local
.env.*.local

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json   # optional: remove this line if you want to lock deps in VCS

# --- TypeScript build output ---
dist/
build/
*.tsbuildinfo

# --- Logs ---
logs/
*.log

# --- Python (virtualenv used in this project) ---
.venv/
__pycache__/
*.py[cod]

# --- OS noise ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Misc ---
*.tmp
*.bak
coverage/
