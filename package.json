{
  "name": "atomic-git-commit",
  "version": "1.0.0",
  "description": "AI-powered atomic commit machine using SumoPod + RTK token-compressed git commands",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start:built": "node dist/index.js",
    "dev": "nodemon --exec \"node --loader ts-node/esm src/index.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NabilRobert/atomic-git.git"
  },
  "keywords": [
    "git",
    "conventional-commits",
    "ai",
    "sumopod",
    "rtk",
    "atomic-commits"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/NabilRobert/atomic-git/issues"
  },
  "homepage": "https://github.com/NabilRobert/atomic-git#readme",
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
